#!/bin/bash

# gog — Structural wrapper that intercepts bare `gog` calls and routes
# read-only operations to allowlisted wrapper scripts automatically.
#
# WHY THIS EXISTS:
# Amber (the LLM) repeatedly uses bare `gog` for email reads despite docs
# saying to use gog-email-read.sh. This wrapper is resolved via OpenClaw's
# pathPrepend setting (NOT shell PATH) and transparently routes safe reads
# to the allowlisted scripts.
#
# IMPORTANT: This wrapper lives in safeBinTrustedDirs, so it auto-approves.
# Therefore it MUST NOT pass dangerous commands (send/reply/create) through
# to the real binary — that would bypass exec-approval. Instead, dangerous
# commands are BLOCKED with an error message telling the LLM to use the
# full path /usr/local/bin/gog (which is NOT trusted, so approval fires).
#
# INSTALL:
#   1. Set pathPrepend: openclaw config set tools.exec.pathPrepend \
#      '["/Users/amberives/.openclaw/workspace/scripts"]'
#   2. chmod +x this file
#   3. Restart gateway: openclaw gateway restart
#
# TEST:
#   gog gmail labels list  → should auto-approve (routed to gog-email-read.sh)
#   gog gmail send ...     → should print error telling LLM to use /usr/local/bin/gog

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CMD="$*"

# ─── DANGEROUS patterns — BLOCK these (do NOT pass through) ───
# These MUST be blocked, not forwarded. This wrapper is in a trusted dir,
# so anything it exec's would bypass approval. Instead, print an error
# that tells the LLM to use the real binary path directly.
DANGEROUS_PATTERNS=(
    "gmail send"
    "gmail reply"
    "gmail draft"
    "gmail delete"
    "gmail trash"
    "cal create"
    "cal update"
    "cal delete"
)

# ─── EMAIL READ patterns → route to gog-email-read.sh ───
EMAIL_READ_PATTERNS=(
    "gmail messages search"
    "gmail message search"
    "gmail search"
    "gmail messages get"
    "gmail message get"
    "gmail messages list"
    "gmail message list"
    "gmail threads get"
    "gmail thread get"
    "gmail threads list"
    "gmail thread list"
    "gmail labels list"
    "gmail labels get"
    "gmail inbox"
)

# ─── EMAIL TAG patterns → route to gog-email-tag.sh ───
EMAIL_TAG_PATTERNS=(
    "gmail thread modify"
    "gmail threads modify"
)

# ─── CALENDAR READ patterns → route to gog-cal-read.sh ───
CAL_READ_PATTERNS=(
    "cal events"
    "cal get"
    "cal list"
)

# === STEP 1: Block dangerous patterns ===
for pattern in "${DANGEROUS_PATTERNS[@]}"; do
    if [[ "$CMD" == *"$pattern"* ]]; then
        echo "BLOCKED: This wrapper does not allow write operations (matched: $pattern)."
        echo "Write commands require Dave's approval via exec-approval."
        echo ""
        echo "Run this command instead:"
        echo "  /usr/local/bin/gog $CMD"
        exit 1
    fi
done

# === STEP 2: Route email reads ===
for pattern in "${EMAIL_READ_PATTERNS[@]}"; do
    if [[ "$CMD" == *"$pattern"* ]]; then
        exec "$SCRIPT_DIR/gog-email-read.sh" "$@"
    fi
done

# === STEP 3: Route email tags ===
for pattern in "${EMAIL_TAG_PATTERNS[@]}"; do
    if [[ "$CMD" == *"$pattern"* ]]; then
        exec "$SCRIPT_DIR/gog-email-tag.sh" "$@"
    fi
done

# === STEP 4: Route calendar reads ===
for pattern in "${CAL_READ_PATTERNS[@]}"; do
    if [[ "$CMD" == *"$pattern"* ]]; then
        exec "$SCRIPT_DIR/gog-cal-read.sh" "$@"
    fi
done

# === STEP 5: Unknown commands — block with helpful error ===
# Safer to block unknown commands than to pass them through,
# since this wrapper is in a trusted directory.
echo "UNKNOWN COMMAND: This wrapper doesn't recognize: gog $CMD"
echo "If this is a read operation, add the pattern to scripts/gog."
echo "If this is a write operation, use the full path:"
echo "  /usr/local/bin/gog $CMD"
exit 1
