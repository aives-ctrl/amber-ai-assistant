#!/bin/bash

# gog — Structural wrapper that intercepts bare `gog` calls.
# Routes safe read operations to gog-real (a HARD COPY of /usr/local/bin/gog
# that lives in the trusted scripts dir, so OpenClaw auto-approves it).
# Blocks dangerous operations (send/reply/create) to force the LLM to use
# the full path /usr/local/bin/gog, which triggers exec-approval.
#
# INSTALL (on Amber's machine):
#   1. Ensure scripts dir is in PATH (via .zshrc)
#   2. Copy binary: cp /usr/local/bin/gog <scripts-dir>/gog-real
#   3. Hard restart gateway: pkill -f openclaw-gateway && sleep 2 && openclaw gateway restart
#
# WHY gog-real: OpenClaw monitors exec() calls. If the wrapper calls
# /usr/local/bin/gog directly, OpenClaw sees a new binary outside the
# trusted dir and triggers approval. By exec'ing gog-real (a hard copy
# IN the trusted dir), the entire chain stays in trusted territory.
#
# WHY HARD COPY, NOT SYMLINK: OpenClaw resolves symlinks to their real
# path before checking safeBinTrustedDirs. A symlink in the trusted dir
# pointing to /usr/local/bin/gog still resolves to /usr/local/bin/gog
# (not in trusted dir) → triggers approval. A hard copy IS a real file
# in the trusted dir → auto-approves. After gog binary updates, re-copy:
#   rm <scripts-dir>/gog-real && cp /usr/local/bin/gog <scripts-dir>/gog-real

REAL_GOG="/Users/amberives/.openclaw/workspace/scripts/gog-real"
CMD="$*"

# ─── DANGEROUS patterns — BLOCK (do NOT pass through) ───
DANGEROUS_PATTERNS=(
    "gmail send"
    "gmail reply"
    "gmail draft"
    "gmail delete"
    "gmail trash"
    "cal create"
    "cal update"
    "cal delete"
)

# ─── SAFE READ patterns — pass through to real binary ───
SAFE_PATTERNS=(
    "gmail messages search"
    "gmail message search"
    "gmail search"
    "gmail messages get"
    "gmail message get"
    "gmail messages list"
    "gmail message list"
    "gmail threads get"
    "gmail thread get"
    "gmail threads list"
    "gmail thread list"
    "gmail labels list"
    "gmail labels get"
    "gmail inbox"
    "gmail thread modify"
    "gmail threads modify"
    "cal events"
    "cal get"
    "cal list"
    "auth status"
    "auth login"
)

# === STEP 1: Block dangerous patterns ===
for pattern in "${DANGEROUS_PATTERNS[@]}"; do
    if [[ "$CMD" == *"$pattern"* ]]; then
        # ─── Threading validation for sends ───
        # Catch the #1 mistake: using --to for a reply instead of --reply-to-message-id
        if [[ "$CMD" == *"gmail send"* ]]; then
            if [[ "$CMD" == *"--to"* && "$CMD" != *"--reply-to-message-id"* ]]; then
                # Check if subject looks like a reply (RE: or Re:)
                if [[ "$CMD" =~ (--subject[[:space:]]+\"?(RE:|Re:|re:)) ]]; then
                    echo ""
                    echo "⚠️  THREADING ERROR: Subject starts with 'RE:' but you're using --to."
                    echo "    This will create a NEW standalone email, NOT a threaded reply."
                    echo "    The recipient will see it as a separate conversation."
                    echo ""
                    echo "    FIX: Replace --to with --reply-to-message-id <messageId> --reply-all"
                    echo "    If you don't have the messageId, re-read the original email first."
                    echo ""
                fi
            fi
            # Check for --body without -html
            if [[ "$CMD" == *"--body "* && "$CMD" != *"--body-html"* ]]; then
                echo ""
                echo "⚠️  FORMAT ERROR: Using --body (plain text) instead of --body-html."
                echo "    This will send in tiny default font with no formatting."
                echo "    FIX: Use --body-html with <div style=\"font-size:18px\">...</div>"
                echo ""
            fi
        fi
        echo "BLOCKED: Write operations must use the full path for approval."
        echo "Run this instead:"
        echo "  /usr/local/bin/gog $CMD"
        exit 1
    fi
done

# === STEP 2: Allow safe patterns (call real binary directly) ===
for pattern in "${SAFE_PATTERNS[@]}"; do
    if [[ "$CMD" == *"$pattern"* ]]; then
        exec "$REAL_GOG" "$@"
    fi
done

# === STEP 3: Unknown commands — block ===
echo "UNKNOWN COMMAND: gog $CMD"
echo "If this is a read operation, add the pattern to scripts/gog."
echo "If this is a write operation, use:"
echo "  /usr/local/bin/gog $CMD"
exit 1
