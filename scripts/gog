#!/bin/bash

# gog — Structural wrapper that intercepts bare `gog` calls.
# Routes safe read operations directly to the real binary (auto-approved
# because this wrapper is in a trusted location). Blocks dangerous
# operations (send/reply/create) to force the LLM to use the full path
# /usr/local/bin/gog, which triggers exec-approval.
#
# INSTALL:
#   ln -sf /path/to/this/script /opt/homebrew/bin/gog
#   openclaw gateway restart
#
# The symlink in /opt/homebrew/bin/ (a safeBinTrustedDirs directory) means
# OpenClaw auto-approves this wrapper. Reads pass through to the real
# binary. Sends are blocked, forcing the LLM to use the full path which
# triggers proper exec-approval.

REAL_GOG="/usr/local/bin/gog"
CMD="$*"

# ─── DANGEROUS patterns — BLOCK (do NOT pass through) ───
DANGEROUS_PATTERNS=(
    "gmail send"
    "gmail reply"
    "gmail draft"
    "gmail delete"
    "gmail trash"
    "cal create"
    "cal update"
    "cal delete"
)

# ─── SAFE READ patterns — pass through to real binary ───
SAFE_PATTERNS=(
    "gmail messages search"
    "gmail message search"
    "gmail search"
    "gmail messages get"
    "gmail message get"
    "gmail messages list"
    "gmail message list"
    "gmail threads get"
    "gmail thread get"
    "gmail threads list"
    "gmail thread list"
    "gmail labels list"
    "gmail labels get"
    "gmail inbox"
    "gmail thread modify"
    "gmail threads modify"
    "cal events"
    "cal get"
    "cal list"
    "auth status"
    "auth login"
)

# === STEP 1: Block dangerous patterns ===
for pattern in "${DANGEROUS_PATTERNS[@]}"; do
    if [[ "$CMD" == *"$pattern"* ]]; then
        echo "BLOCKED: Write operations must use the full path for approval."
        echo "Run this instead:"
        echo "  /usr/local/bin/gog $CMD"
        exit 1
    fi
done

# === STEP 2: Allow safe patterns (call real binary directly) ===
for pattern in "${SAFE_PATTERNS[@]}"; do
    if [[ "$CMD" == *"$pattern"* ]]; then
        exec "$REAL_GOG" "$@"
    fi
done

# === STEP 3: Unknown commands — block ===
echo "UNKNOWN COMMAND: gog $CMD"
echo "If this is a read operation, add the pattern to scripts/gog."
echo "If this is a write operation, use:"
echo "  /usr/local/bin/gog $CMD"
exit 1
